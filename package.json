{
  "name": "dot-display",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Matrix display server — renders apps for a 64x32 RGB LED matrix",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env --dns-result-order=ipv4first src/index.ts",
    "start": "tsx --env-file-if-exists=.env --dns-result-order=ipv4first src/index.ts",
    "preview": "PUBLISHER=terminal tsx --env-file-if-exists=.env --dns-result-order=ipv4first src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "mqtt": "^5.10.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
